# Database
DATABASE_URL=postgresql://user:password@localhost:5432/family_tree

# JWT (generate strong random secrets)
JWT_SECRET=change-me-32-chars-minimum
JWT_REFRESH_SECRET=change-me-different-32-chars-minimum

# Server
PORT=4000
NODE_ENV=development

# Frontend URL (for CORS + email links)
FRONTEND_URL=http://localhost:5173
CLIENT_URL=http://localhost:5173

# Super Admin
SUPER_ADMIN_EMAIL=your@email.com

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Family Tree <your@gmail.com>

# File Storage (Cloudflare R2 or S3 - Phase 4)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=family-tree-photos
