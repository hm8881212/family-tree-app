# ============================================================
# .env.example — TEMPLATE ONLY. Never put real values here.
# Copy to .env.local and fill in your actual secrets.
# .env.local is gitignored and must NEVER be committed.
# ============================================================

# Database
DATABASE_URL=postgresql://CHANGE_ME_USER:CHANGE_ME_PASS@localhost:5432/family_tree

# JWT (generate strong random secrets — never use these defaults)
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_64
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_openssl_rand_hex_64

# Server
PORT=4000
NODE_ENV=development

# Frontend URL (for CORS + email links)
FRONTEND_URL=http://localhost:5173
CLIENT_URL=http://localhost:5173

# Super Admin
SUPER_ADMIN_EMAIL=CHANGE_ME_your_admin@email.com

# Email (SMTP)
# For Gmail: use an App Password (not your real password)
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=CHANGE_ME_your@gmail.com
SMTP_PASS=CHANGE_ME_your-gmail-app-password
SMTP_FROM=Family Tree <CHANGE_ME_your@gmail.com>

# File Storage (Cloudflare R2 or S3)
# R2_ACCOUNT_ID=CHANGE_ME
# R2_ACCESS_KEY_ID=CHANGE_ME
# R2_SECRET_ACCESS_KEY=CHANGE_ME
# R2_BUCKET=family-tree-photos
